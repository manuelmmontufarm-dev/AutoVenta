# ── WhatsApp Cloud API (Meta for Developers → tu app → WhatsApp) ─────────────
# OPCIONALES en el entorno: el bot arranca sin ellas y levanta el webhook.
# Cada deploy (staging con el tester, cliente con su WhatsApp Business) pone las
# suyas aquí en Railway. La DB (settings key channel_config) puede sobrescribir
# el token en caliente si algún día expones un editor — útil porque el token
# permanente caduca/rota sin redeploy.
WHATSAPP_TOKEN=            # token permanente del system user
WHATSAPP_APP_SECRET=       # App Secret (valida la firma del webhook)
WHATSAPP_VERIFY_TOKEN=     # string que tú inventas; el mismo se pone en Meta
WHATSAPP_PHONE_ID=         # Phone number ID del número del negocio
SELLER_PHONE=              # número del vendedor para alertas, ej. 5939XXXXXXXX
# SELLER_NAME=Manuel Montúfar
# HUB_PUBLIC_URL=https://autoventa-staging.up.railway.app/admin

# ── OpenAI / GPT ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# GPT-4o mini es el valor económico recomendado para este piloto.
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_CLASSIFIER_MODEL=gpt-4o-mini

# ── Base de datos ─────────────────────────────────────────────────────────────
# Railway Postgres: referenciar ${{Postgres.DATABASE_URL}} en Variables (red interna, sin SSL).
# Supabase / proxy público: pegar la URI y además poner PGSSL=require.
DATABASE_URL=postgresql://...
# PGSSL=require              # solo si la DB exige SSL (Supabase, proxy público de Railway)

# ── Catálogo Contífico (fuente primaria) ─────────────────────────────────────
# La API Key se envía como valor crudo del header Authorization.
# Nunca poner estas credenciales en código, frontend, fixtures o Git.
CONTIFICO_API_KEY=
# CONTIFICO_BASE_URL=https://api.contifico.com/sistema/api/v2
# CONTIFICO_CUSTOMER_PVP=pvp1       # pvp1 | pvp2 | pvp3 | pvp4
# CONTIFICO_CUSTOMER_PRICE_DIVISOR=0.5625
# CONTIFICO_MINIMUM_PRICE_DIVISOR=0.75
# CONTIFICO_CATALOG_SYNC_INTERVAL_MS=300000

# ── Catálogo en Google Sheets (OPCIONAL) ──────────────────────────────────────
# Si faltan estas 3, el bot igual arranca y levanta el webhook; solo no cotiza
# con precios hasta conectarlo. (Pendiente: migrar a la API de Contífico.)
# Service account con acceso de lectura a la hoja (compartir la hoja con su email)
# CATALOG_SHEET_ID=          # el id de la URL de la hoja
# GOOGLE_SERVICE_ACCOUNT_EMAIL=xxx@yyy.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# CATALOG_SYNC_INTERVAL_MS=300000

# ── Panel en línea (/mensajes, /configuracion/ia, /tester) ────────────────────
# Clave que protege la API de administración del hub.
# Con NODE_ENV=production y SIN ADMIN_KEY, el panel se BLOQUEA (fail-closed).
# En desarrollo local sin ADMIN_KEY queda abierto para no frenar las pruebas.
# ADMIN_KEY=una-clave-larga-que-tu-inventes
# NODE_ENV=production        # Railway lo pone solo; fuerza el fail-closed del panel

# ── Fases del producto (entrega por etapas) ──────────────────────────────────
# Fase activa por defecto cuando la DB aún no tiene phase_config guardado.
# "1" (solo núcleo) | "2" | "3" | "all". El entregable de Depot arranca en "1";
# el staging conviene en "all" para ver todo. Se sobrescribe desde el panel.
# PHASES_DEFAULT=1

# ── Panel central de administración (/panel) ─────────────────────────────────
# El panel vive en otro origen y llama a /api/phases de cada cliente. Por
# defecto el API responde CORS a cualquier origen (la seguridad real es la
# ADMIN_KEY). Para restringirlo, pon aquí el origen exacto del panel.
# ADMIN_PANEL_ORIGIN=https://autoventa-staging.up.railway.app

# ── Comportamiento ────────────────────────────────────────────────────────────
# PORT=3000
# DEBOUNCE_MS=5000
# BOT_PAUSE_HOURS=6
