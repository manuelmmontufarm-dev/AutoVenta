# Inventa este valor tú mismo (cualquier string) y pégalo también
# en el campo "Verify token" cuando configures el Callback URL en Meta.
VERIFY_TOKEN=PEGA_UN_STRING_SECRETO_AQUI

# App Secret de tu app de Meta (App Dashboard → App settings → Basic → App secret).
# Se usa para validar la firma X-Hub-Signature-256 de cada webhook.
APP_SECRET=PEGA_TU_APP_SECRET_AQUI

PORT=3000
